# Python bytecode and cache (Generated automatically when running scripts, not needed in version control)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Local Environment & Secrets (Never commit credentials, API keys, or AWS tokens)
.env
.secrets
secrets.json

# Virtual Environments (Local dependencies installed via pip)
venv/
.venv/
env/
backend-env/
dbt-env/

# IDE / Editor Settings (Keeps personal VS Code setup out of the repository)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS generated files
.DS_Store
Thumbs.db

# Ignore specific files
temp.py
temp registry items.txt

# dbt build artifacts (regenerated by `dbt run` / `dbt docs generate`)
target/
dbt_packages/
logs/

# Evidence generated files
dashboard/sources/prices/prices.csv
dashboard/.evidence/
dashboard/build/